<div
  class="d-flex justify-content-between align-items-center mb-3 p-3"
  style="border: 0.5px solid black; border-radius: 10px"
>
  <!-- Select All -->
  <div class="form-check">
    <input class="form-check-input" type="checkbox" id="selectAllCheckbox" />
    <label class="form-check-label fw-semibold" for="selectAllCheckbox">
      Select All
    </label>
  </div>

  <!-- Actions -->
  <div class="d-flex gap-2">
    <button
        id="bulkActionBtn"
        class="btn btn-outline-danger btn-sm px-3 fw-semibold"
        type="submit"
        formaction="/dashboard/<%= actionType === 'delete' ? 'delete-selected' : 'unsave-selected' %>"
        disabled
    >
        <%= actionType === 'delete' ? 'Delete Selected' : 'Unsave Selected' %>
    </button>

    <button
      class="btn btn-danger btn-sm px-3 fw-semibold"
      type="button"
      data-bs-toggle="modal"
      data-bs-target="#confirmModal"
      data-action="/dashboard/<%= actionType === 'delete' ? 'delete-all' : 'unsave-all' %>"
    >
      <%= actionType === 'delete' ? 'Delete All' : 'Unsave All' %>
    </button>
  </div>
</div>
