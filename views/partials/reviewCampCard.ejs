<div class="card mb-3 p-3">

  <!-- Campground Context -->
  <div class="d-flex align-items-center gap-3 mb-2">

    <img 
      src="<%= review.campground?.images?.[0]?.url || '' %>"
      style="width:70px; height:70px; object-fit:cover; border-radius:10px;"
      loading="lazy"
      alt="reviewed spot image"
    >

    <div>
      <p class="mb-1 text-muted">Reviewed:</p>
      <h4 class="mb-1 fw-semibold"><%= review.campground.title %></h4>

      <small class="text-muted">
        📍 <%= review.campground.location %> • 
        <a href="/campgrounds/<%= review.campground._id %>">View Post →</a>
      </small>
    </div>

  </div>

  <hr>

  <!-- SAME REVIEW CARD -->
  <%- include('./reviewCard', { 
    review, 
    campId: review.campground._id,  
    currentUrl
  }) %>

</div>