<nav class="navbar navbar-expand-lg campex-nav py-2">
  <div class="container-fluid mx-3">

    <a class="navbar-brand d-flex align-items-center" href="/">
      <img src="/images/logo.png" class="nav-logo" alt="Campexxa Logo">
    </a>

    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavAltMarkup">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarNavAltMarkup">

      <div class="navbar-nav ms-3">
        <a class="nav-link campex-nav-link" href="/">Home</a>
        <a class="nav-link campex-nav-link" href="/campgrounds">Spots</a>
        <a class="nav-link campex-nav-link" href="/campgrounds/new">New Spot</a>
      </div>

      <!-- 🔍 Global Search Wrapper -->
      <form id="global-search-form" class="d-flex position-relative flex-grow-1 ms-3" action="/campgrounds" method="GET">
          <input 
              type="search" 
              id="globalSearchInput" 
              name="search" 
              class="form-control rounded-start ps-4"
              placeholder="Search a spot by name ..."
              autocomplete="off"
              value="<%= typeof search !== 'undefined' ? search : '' %>"
          >

          <!-- Search Button -->
          <button type="submit" class="search-btn rounded-end">
            🔍︎
          </button>

          <!-- 🔽 Live suggestions dropdown -->
          <div id="searchSuggestions" class="search-suggestion-box"></div>
          <button type="submit" hidden></button>
      </form>
      <!-- 📍 Near Me Button (outside the form) -->
      <button id="navbarNearMeBtn" class="near-me-cta px-2 mx-auto">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-map-pin w-4 h-4" aria-hidden="true"><path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"></path><circle cx="12" cy="10" r="3"></circle></svg> 
        Near Me
      </button>

      <div class="navbar-nav ms-3 text-center">
        <% if(!currentUser){ %>
          <a class="nav-link campex-nav-link" href="/login">Login</a>
        <% } else { %>
          <div class="dropdown">
            <button class="btn d-flex align-items-center justify-content-center w-100 gap-1 dropdown-toggle" data-bs-toggle="dropdown">
              <!-- Profile Circle -->
              <% if (currentUser.profileImage && currentUser.profileImage.url) { %>
                <img 
                  src="<%= currentUser.profileImage.url %>" 
                  style="width:32px; height:32px; border-radius:50%; object-fit:cover;"
                >
              <% } else { %>
                <div style="width:32px; height:32px; border-radius:50%; background:#000; color:#fff; display:flex; align-items:center; justify-content:center;">
                  <%= currentUser.profileInitial %>
                </div>
              <% } %>
              <span class="nav-link campex-nav-link"><%= currentUser.username %></span>
            </button>
            <ul class="dropdown-menu p-1">
              <li>
                <a class="dropdown-item" href="/dashboard">Dashboard</a>
              </li>
            </ul>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</nav>

<script src="/javascripts/geoLocation.js"></script>
<script src="/javascripts/dynamicSearch.js"></script>




