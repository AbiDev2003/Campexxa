<% layout('layouts/boilerplate') %>
<link rel="stylesheet" href="/stylesheets/stars.css">
<style>
  .card-hover:hover {
    box-shadow: 0 0 40px rgba(0,123,255,0.55);
    transform: translateY(-5px);
  }
</style>

<div class="campgrounds-content">
  <div class="d-flex justify-content-between align-items-center mb-1">

    <!-- Filters Button (LEFT) -->
    <button class="btn btn-primary" id="filterToggle">
      ☰ Filters
    </button>

    <!-- Sort Dropdown (RIGHT) -->
    <div class="d-flex align-items-center">
      <label class="me-2 text-muted fw-semibold mb-0">Sort by:</label>
      <select id="campground-sort" class="form-select" style="width: 180px;">
        <option value="">Sort by</option>
        <option value="newest">Newest first</option>
        <option value="oldest">Oldest first</option>
        <option value="ratingHighLow">Ratings: High to low</option>
        <option value="ratingLowHigh">Ratings: Low to High</option>
        <option value="distanceNear">Distance: Near to far</option>
        <option value="distanceFar">Distance: Far to near</option>
        <option value="priceHighLow">Cost: High to low</option>
        <option value="priceLowHigh">Cost: Low to High</option>
      </select>
    </div>

  </div>

  <!-- MAP + FILTER UI -->
  <div class="map-wrapper">
    <div class="filters-overlay" id="filtersPanel">
      <%- include('filters') %>
    </div>

    <div id="cluster-map"></div>
  </div>
  
    <div class="container my-4">
      <!-- <h1 class="camp-header">All Campgrounds</h1> -->
      <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-4">
        <% for(let campground of campgrounds){ %>
          <div class="col">
            <div class="card card-hover h-100"  style="border:none; border-radius:12px; background-color:white; transition:box-shadow 0.3s ease, transform 0.3s ease;">

              <% if(campground.images.length){ %>
                <img crossorigin="anonymous" class="card-img-top" style="height:200px; object-fit:cover;"
                    alt="campground image" 
                    src="<%= campground.images[0].url %>">
              <% } else { %>
                <img crossorigin="anonymous" class="card-img-top" style="height:200px; object-fit:cover;"
                    alt="campground image" 
                    src="https://via.placeholder.com/400x250?text=No+Image">
              <% } %>

            <div class="card-body camp-card">

              <!-- TITLE + STARS + RATING -->
              <div class="d-flex justify-content-between align-items-center mb-2">
                
                <h5 class="fw-semibold mb-0"><%= campground.title %></h5>

                <div class="d-flex align-items-center gap-2">
                  <p class="starability-result mb-0" 
                    data-rating="<%= Math.round(campground.avgRating || 0) %>"></p>

                  <span class="text-muted fw-semibold"><%= campground.avgRating %></span>
                </div>

              </div>

              <!-- LOCATION -->
              <p class="text-muted small mb-2 d-flex align-items-center gap-1 pt-2 pb-2">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0" fill="#ef4444" stroke="#dc2626"></path>
                  <circle cx="12" cy="10" r="3" fill="white" stroke="white"></circle>
              </svg>
                <%= campground.location %>
              </p>

              <!-- DESCRIPTION -->
              <p class="card-text text-truncate pb-2"><%= campground.description %></p>

              <!-- CTA BUTTON -->
              <a class="btn camp-view-btn w-100 fw-bold py-2"
                href="/campgrounds/<%= campground._id %>">
                View <%= campground.title %> 
                <!-- <span class="camp-ext-icon">↗</span> -->
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h6v6"></path><path d="M10 14 21 3"></path><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path></svg>
              </a>
            </div>
            </div>
          </div>
        <% } %>
      </div>

    </div>
  </main>
</div>


<script>
  const mapToken = '<%-process.env.MAPBOX_TOKEN %>';
  const campgrounds = { features: <%- JSON.stringify(campgrounds) %>} 
</script>

<script>
  const filterBtn = document.getElementById("filterToggle");
  const filtersPanel = document.getElementById("filtersPanel");
  filterBtn.addEventListener("click", (e) => {
    e.stopPropagation();
    filtersPanel.classList.toggle("show");
  });
  // by clicking inside filter , it does not closed
  filtersPanel.addEventListener("click", (e) => {
    e.stopPropagation();
  })
  // by clicking in window outside filter it get closed 
  window.addEventListener("click", () => {
    if(filtersPanel.classList.contains("show")){
      filtersPanel.classList.remove("show"); 
    }
  })

</script>

<script src="/javascripts/clusterMap.js"></script>
<script src="/javascripts/sort.js"></script>

