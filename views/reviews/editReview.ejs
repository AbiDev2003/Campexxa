<% layout('layouts/boilerplate') %>
<link rel="stylesheet" href="/stylesheets/stars.css">

<div class="d-flex justify-content-center align-items-center" style="min-height: calc(100vh - 120px);">
  <div class="card shadow-lg border-0" style="width: 100%; max-width: 650px; border-radius: 18px; background:#f8f9fa;">
    <div class="card-body p-4 p-md-5">

      <h3 class="text-center mb-4 fw-bold text-dark">Edit Review</h3>

      <form action="/campgrounds/<%= campground._id %>/reviews/<%= review._id %>?_method=PUT" method="POST" class="validated-form" enctype="multipart/form-data" novalidate>
        <input type="hidden" name="redirectTo" value="<%= redirectTo %>" aria-label="hidden" >
        <!-- Stars -->
        <fieldset class="starability-grow mb-3">
          <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" aria-label="checked" checked />

          <input type="radio" id="rate1" name="review[rating]" value="1" <%= review.rating === 1 ? 'checked' : '' %>/>
          <label for="rate1" title="Terrible">1 star</label>

          <input type="radio" id="rate2" name="review[rating]" value="2" <%= review.rating === 2 ? 'checked' : '' %>/>
          <label for="rate2" title="Not good">2 stars</label>

          <input type="radio" id="rate3" name="review[rating]" value="3" <%= review.rating === 3 ? 'checked' : '' %>/>
          <label for="rate3" title="Average">3 stars</label>

          <input type="radio" id="rate4" name="review[rating]" value="4" <%= review.rating === 4 ? 'checked' : '' %>/>
          <label for="rate4" title="Very good">4 stars</label>

          <input type="radio" id="rate5" name="review[rating]" value="5" <%= review.rating === 5 ? 'checked' : '' %>/>
          <label for="rate5" title="Amazing">5 stars</label>
        </fieldset>

        <!-- Text -->
        <div class="mb-3">
          <label for="reviewBody" class="form-label fw-semibold">Your Review</label>
          <textarea 
            class="form-control" 
            id="reviewBody"
            name="review[body]" 
            rows="4"
            required
            maxlength="500"
            style="border-radius: 12px; padding: 12px;"
          ><%=review.body  %></textarea>
          <p class="text-muted small" id="reviewBodyCount">0 / 500</p>
        </div>

        <% if (review.images && review.images.length > 0) { %>
          <div class="mb-3">
            <h4 class="fw-bold mb-2">Existing Images</h4>
            <!-- Select All -->
            <div class="form-check mb-2">
              <input type="checkbox" id="selectAllReviewImages" class="form-check-input" data-selectall="delete-checkbox">
              <label class="form-check-label" for="selectAllReviewImages">Select All</label>
            </div>
            <!-- Existing Image Grid -->
            <div class="row g-3">
              <% review.images.forEach((img, i) => { %>
                <div class="col-6 col-md-4">
                  <div class="text-center">
                    <img src="<%= img.url %>" class="img-fluid rounded img-thumbnail" alt="review image" loading="lazy">
                    <div class="form-check-inline mt-1">
                      <input class="form-check-input delete-checkbox" type="checkbox" id="revImg-<%= i %>" name="deleteReviewImages[]" value="<%= img.filename %>" aria-label="existing images">
                    </div>
                  </div>
                </div>
              <% }) %>
            </div>
          </div>
        <% } %>

      <!-- Drag & Drop Upload Box -->
      <div 
        class="border border-2 border-secondary bg-light d-flex flex-column justify-content-center align-items-center mb-3"
        style="height: 140px; border-style: dashed; border-radius: 12px; cursor: pointer;"
        data-droparea="reviewImages"
        data-existing="<%= review.images.length %>"
      >
        <img class="upload-img" src="/images/cloud-upload.png" alt="upload picture" loading="lazy"/>
          <p class="mb-1 fw-semibold drop-text">Drag & drop images here</p>
          <p class="text-muted small drop-subtext">or click to select files</p>
      </div>

      <p class="text-muted small mb-2">
        Maximum 5 images allowed. Existing: <%= review.images.length %>
      </p>

      <!-- Preview Grid for NEW images -->
      <div class="mini-preview-grid mb-3" data-preview="reviewImages"></div>

      <!-- Hidden actual file input -->
      <input 
        type="file"
        name="reviewImages"
        multiple
        accept=".jpg,.jpeg,.png"
        class="form-control"
        style="display:none;"
        data-fileinput="reviewImages"
        aria-label="hidden input"
      />


      <button class="btn btn-success w-100 py-2 fw-bold" style="border-radius: 12px;" >
        Submit Review
      </button>
      <a href="/campgrounds/<%= campground._id %>/reviews" class="btn btn-danger w-100 mt-2 fw-bold" style="border-radius: 12px;" >
          Cancel
      </a>
      </form>
    </div>
  </div>
</div>

<script defer src="/javascripts/checkBoxSelect.js"></script>
<script defer src="/javascripts/dragdrop.js"></script>
<script defer src="/javascripts/charCount.js"></script>
 <script defer src="/javascripts/validateForms.js"></script>



