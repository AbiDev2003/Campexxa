<% layout('layouts/boilerplate') %>
<link rel="stylesheet" href="/stylesheets/stars.css">


<div class="container py-4">
    <a href="/campgrounds/<%= campground._id %>" class="text-decoration-none fw-bold">
        ← Back to Campground
    </a>
    <h2 class="fw-bold mb-3"><%= campground.title %> — Reviews</h2>
    <!-- Summary Card -->
    <div class="card p-3 mb-4">
        <!-- TOP REVIEW STATISTICS (3 COLUMN LAYOUT) -->
        <div class="row g-4 mb-4">

        <!-- TOTAL REVIEWS -->
        <div class="col-12 col-lg-4">
            <div class="card p-3 h-100">
            <h5 class="fw-bold mb-1">Total Reviews</h5>
            <h2 class="fw-bold"><%= totalReviews %></h2>
            <p class="text-muted mt-2">
                Total <%= aboveFourPercentage %>% have given 4 stars and above
            </p>
            </div>
        </div>

        <!-- AVERAGE RATING -->
        <div class="col-12 col-lg-4">
            <div class="card p-3 h-100">
            <h5 class="fw-bold mb-1">Average Rating</h5>
            <div class="d-flex align-items-center mb-2">
                <span class="fs-1 fw-bold me-2"><%= avgRating %></span>
                <p class="starability-result" data-rating="<%= Math.round(avgRating) %>"></p>
            </div>
            <p class="text-muted">
                Based on <%= totalReviews %> reviews
            </p>
            </div>
        </div>

        <!-- PERCENTAGE BREAKDOWN -->
        <div class="col-12 col-lg-4">
            <div class="card p-3 h-100">
            <h6 class="fw-bold mb-3"><%= dateRange %></h6>
            <% [5,4,3,2,1].forEach((star) => { %>
                <div class="d-flex align-items-center mb-2">
                <span style="width: 40px;"><%= star %>⭐</span>

                <div class="progress flex-grow-1 me-2" style="height: 10px;">
                    <div
                    class="progress-bar bg-success"
                    role="progressbar"
                    style="width: <%= starPercentages[star-1] %>%;">
                    </div>
                </div>
                <span><%= starPercentages[star-1] %>%</span>
                </div>
            <% }) %>
            </div>
        </div>
        </div>
        <a href="/campgrounds/<%= campground._id %>/reviews/addReview"
            class="btn btn-primary w-100 fw-bold py-2">
            Leave a Review
        </a>
    </div>

    <div class="d-flex justify-content-end align-items-center mb-3">
        <label class="me-2 text-muted fw-semibold">Sort by:</label>
        <select id="reviewSort" class="form-select" style="width: 180px;">
            <option value="newest" <%= sort === "newest" ? "selected" : "" %>>Newest first</option>
            <option value="oldest" <%= sort === "oldest" ? "selected" : "" %>>Oldest first</option>
            <option value="highest" <%= sort === "highest" ? "selected" : "" %>>Highest to lowest rating</option>
            <option value="lowest" <%= sort === "lowest" ? "selected" : "" %>>Lowest to highest rating</option>
        </select>
    </div>

    <!-- Pagination Top Bar -->
    <% if (totalReviews > 5) { %>
    <div class="d-flex justify-content-between align-items-center mb-3">

        <!-- Left: Showing Range -->
        <div class="text-muted small fw-semibold">
        <% 
            const start = (page - 1) * limit + 1; 
            const end = Math.min(page * limit, totalReviews); 
        %>
        Showing <%= start %> – <%= end %> of <%= totalReviews %> reviews
        </div>

        <!-- Right: Reviews Per Page -->
        <div class="d-flex align-items-center">
        <label class="me-2 small fw-semibold">Per page:</label>
        <select id="reviewsPerPage" class="form-select form-select-sm" style="width: 80px;">
            <option value="5" <%= limit == 5 ? 'selected' : '' %>>5</option>

            <% if (totalReviews >= 10) { %>
                <option value="10" <%= limit == 10 ? 'selected' : '' %>>10</option>
            <% } %>

            <% if (totalReviews >= 20) { %>
                <option value="20" <%= limit == 20 ? 'selected' : '' %>>20</option>
            <% } %>

            <% if (totalReviews >= 50) { %>
                <option value="50" <%= limit == 50 ? 'selected' : '' %>>50</option>
            <% } %>

            <option value="<%= totalReviews %>" <%= limit == totalReviews ? 'selected' : '' %>>All</option>
        </select>

        </div>
    </div>
    <% } %>

    <!-- Reviews List -->
    <% reviews.forEach(r => { %>
        <div class="card mb-2 review-card">
            <div class="card-body position-relative pt-4">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <div class="profile-initial"><%=r.auther.profileInitial  %></div>
                    <h5 class="fw-bold mb-0"><%= r.auther.firstName %></h5>
                </div>

                <p class="starability-result" data-rating="<%= r.rating %>"></p>
                <p class="mt-1 pt-2"><%= r.body %></p>

                <!-- Review Images (Horizontal Scroll) -->
                <% if (r.images && r.images.length > 0) { %>
                <div class="review-image-scroll mb-3">
                    <% r.images.forEach(img => { %>
                    <img 
                        src="<%= img.url %>" 
                        class="review-thumb"
                        data-gallery="review-<%= r._id %>"
                        data-full="<%= img.url %>"
                    >
                    <% }) %>
                </div>
                <% } %>


                <% if (currentUser && r.auther._id.equals(currentUser._id)) { %>
                    <div class="dropdown" style="position:absolute; top:15px; right:15px;">
                    <button 
                        class="btn btn-link p-0 text-dark" 
                        type="button" 
                        data-bs-toggle="dropdown" 
                        aria-expanded="false"
                        style="font-size: 22px;"
                    >
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-three-dots-vertical" viewBox="0 0 16 16">
                            <path d="M9.5 13a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0m0-5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0m0-5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0"/>
                        </svg>
                    </button>

                    <ul class="dropdown-menu dropdown-menu-end shadow">
                        <li>
                        <a class="dropdown-item" href="/campgrounds/<%= campground._id %>/reviews/<%= r._id %>/edit">
                            Edit
                        </a>
                        </li>

                        <li>
                        <form method="POST" action="/campgrounds/<%= campground._id %>/reviews/<%= r._id %>?_method=DELETE">
                            <button class="dropdown-item text-danger">Delete</button>
                        </form>
                        </li>
                    </ul>
                    </div>
                <% } %>

            </div>
        </div>
    <% }) %>

    <!-- Page Buttons -->
    <% if (totalPages > 1) { %>
    <nav class="d-flex justify-content-center my-3">
        <ul class="pagination">

        <!-- Prev -->
        <li class="page-item <%= page === 1 ? 'disabled' : '' %>">
            <a class="page-link"
            href="?page=<%= page - 1 %>&limit=<%= limit %>&sort=<%= sort %>">
            Previous
            </a>
        </li>

        <!-- Page Numbers -->
        <% for (let p = 1; p <= totalPages; p++) { %>
            <li class="page-item <%= p === page ? 'active' : '' %>">
            <a class="page-link" 
                href="?page=<%= p %>&limit=<%= limit %>&sort=<%= sort %>">
                <%= p %>
            </a>
            </li>
        <% } %>

        <!-- Next -->
        <li class="page-item <%= page === totalPages ? 'disabled' : '' %>">
            <a class="page-link"
            href="?page=<%= page + 1 %>&limit=<%= limit %>&sort=<%= sort %>">
            Next
            </a>
        </li>

        </ul>
    </nav>
    <% } %>

</div>

<script>
  document.getElementById("reviewSort")?.addEventListener("change", function () {
    const selected = this.value;
    const url = new URL(window.location.href);

    url.searchParams.set("sort", selected);
    url.searchParams.set("page", 1); // reset to first page on sort change

    window.location.href = url.toString();
  });
</script>

<script>
  // Change reviews per page
  document.getElementById("reviewsPerPage")?.addEventListener("change", function () {
    const newLimit = this.value;
    const url = new URL(window.location.href);

    url.searchParams.set("limit", newLimit);
    url.searchParams.set("page", 1); // reset to page 1

    window.location.href = url.toString();
  });
</script>


