<% layout('layouts/boilerplate') %>

<div class="auth-page">
  <div class="auth-card">
    <div class="auth-content">
      <h3 class="auth-title">Forgot Password</h3>
      <p class="auth-sub">Enter your email to receive a reset link</p>
  
      <form action="/forgot-password" method="POST">
        <label for="email" class="auth-label fw-semibold">Email</label>
        <input class="auth-input" id="email" type="email" name="email" required>
        <button class="auth-btn-primary mt-3" type="submit" style="background-color: #027e02;">Send reset link</button>
      </form>
    </div>
  </div>
</div>
