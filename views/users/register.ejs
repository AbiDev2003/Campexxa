<% layout('layouts/boilerplate') %>

<div class="auth-page">
  <div class="auth-card">
    <!-- Logo -->
    <div class="auth-brand">
      <img src="/images/logo.png" alt="Campexxa" class="auth-brand-img">
    </div>
    <div class="auth-content">
      <h2 class="auth-title">Create your account</h2>
      <p class="auth-sub">Join Campexxa and explore freely</p>
      <form action="/register" method="POST" class="auth-form" id="registerForm">

        <label class="auth-label fw-semibold" for="fullName">Full Name</label>
        <input class="auth-input" type="text" id="fullName" name="fullName" placeholder="John Doe" required>

        <label class="auth-label mt-3 fw-semibold" for="username">Username</label>
        <input class="auth-input" type="text" id="username" name="username" placeholder=" John Doe" required>
        <small id="usernameFeedback"></small>

        <label class="auth-label mt-3 fw-semibold" for="email">Email</label>
        <input class="auth-input" type="email" id="email" name="email" placeholder="example@gmail.com" required>

        <%- include('../partials/passwordFields', {
          passwordLabel: "Password", 
          passwordPlaceholder: "Enter your password",
          confirmLabel: "Confirm Password",
          confirmPlaceholder: "Confirm your password"
        }) %>

        <!-- terms and conditions -->
        <div class="mt-3 d-flex align-items-start gap-2">
          <input type="checkbox" id="terms" name="terms" required style="margin-top:4px;">
          <label for="terms" class="auth-label" style="font-size:0.9rem;">
            I agree to the 
            <a href="#" data-bs-toggle="modal" data-bs-target="#termsModal" style="text-decoration:none; color:#6366f1; cursor:pointer;">
              Terms & Conditions
            </a>
          </label>
        </div>

        <button class="auth-btn-primary" type="submit">Sign up</button>
      </form>

      <!-- Terms & Conditions Modal -->
      <div class="modal fade" id="termsModal" tabindex="-1">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
          <div class="modal-content" style="border-radius:12px;">
            <div class="modal-header">
              <h5 class="modal-title fw-bold">Terms and Conditions</h5>
              <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" style="font-size:0.93rem; line-height:1.55;">
              <%- include('../partials/termsText') %>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-primary" data-bs-dismiss="modal">Close</button>
            </div>
          </div>
        </div>
      </div>
      <%- include('../partials/oauthButtons', {actionText: 'sign up'}) %>
      <div class="auth-footer mt-3">
        <span>Already have an account?</span>
        <a href="/login">Log in</a>
      </div>
    </div>
  </div>
</div>

<script src="/javascripts/usernameCheck.js"></script>
<script defer src="/javascripts/eyeToggle.js"></script>
<script defer src="/javascripts/pwValidate.js"></script>

