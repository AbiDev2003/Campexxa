<% layout('layouts/boilerplate') %>
<div class="container mt-4">
  <%- include('./header') %>

  <div class="row">
    <div class="col-md-3">
      <%- include('./sidebar') %>
    </div>
    
    <div class="col-md-9">
      <% if(tab === 'campgrounds'){ %>
        <%- include('./campgrounds') %>
      <% }else if(tab === 'saved'){ %>
        <%- include('./saved') %>
      <% }else if(tab === 'reviews'){ %>
        <%- include('./reviews') %>
      <% }else if(tab === 'profile'){ %>
        <%- include('./profile') %>
      <% } %>
    </div>
  </div>
</div>
<%- include('../partials/confirmModal') %>
<script>
  const confirmModal = document.getElementById('confirmModal');

  confirmModal.addEventListener('show.bs.modal', function (event) {
    const button = event.relatedTarget;

    const action = button.getAttribute('data-action');
    const message = button.getAttribute('data-message');

    const form = confirmModal.querySelector('#confirmForm');
    const msg = confirmModal.querySelector('#confirmMessage');

    form.action = action;
    msg.textContent = message || "This action cannot be undone. Are you sure?";
  });
</script>